{
  "name": "billing.io",
  "version": "0.1.0",
  "private": true,
  "main": "electron/dist-electron/main.js",
  "scripts": {
    "dev:next": "next dev",
    "dev:electron": "tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:next\" \"wait-on http://localhost:3000 && npm run dev:electron\"",
    "build:next": "next build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:next && npm run build:electron",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "start": "next start",
    "lint": "eslint"
  },
  "build": {
    "appId": "com.schoolbilling.app",
    "productName": "School Billing Management",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "electron/dist-electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": "."
      }
    ],
    "mac": {
      "category": "public.app-category.education"
    },
    "win": {
      "target": "nsis",
      "icon": "public/desktop.ico"
    }
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mongoose": "^9.2.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}